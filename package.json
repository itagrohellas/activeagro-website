{
  "name": "active-agro-web",
  "version": "0.1.0",
  "private": true,
  "description": "Εταιρικό website της ActiveAgro Α.Ε. — Next.js 15 + Payload CMS",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "payload:generate-types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "payload:generate-importmap": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:importmap",
    "dev:webpack": "next dev",
    "seed": "node -e \"fetch('http://localhost:3000/api/seed', { method: 'POST' }).then(r => r.json()).then(d => console.log(JSON.stringify(d, null, 2))).catch(e => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/db-sqlite": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@vercel/blob": "^0.27.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "graphql": "^16.8.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.11.0",
    "next": "15.3.9",
    "next-intl": "^4.9.1",
    "payload": "3.84.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.3.9",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
