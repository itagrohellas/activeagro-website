# ─────────────────────────────────────────────────────────
# ActiveAgro — Environment variables
# Αντίγραψε σε .env.local για development.
# Σε production (Vercel) τα ορίζεις στο Vercel Dashboard → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────

# === Public ===
# Public site URL (χωρίς trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Payload CMS ===
# Random secret string. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-this-with-a-long-random-string

# === Database ===
# Dev (SQLite, file-based):
DATABASE_URI=file:./activeagro.db
# Production (Postgres στο Neon/Supabase/Vercel Postgres):
# DATABASE_URI=postgresql://user:pass@host/dbname?sslmode=require

# === Media Storage (μόνο για production) ===
# Token από Vercel Dashboard → Storage → Blob → .env.local
# Όταν είναι set, τα uploads πάνε σε Vercel Blob αντί για /media folder.
# BLOB_READ_WRITE_TOKEN=

# === Seed (προαιρετικό σε production) ===
# Token για να καλέσεις POST /api/seed σε production
# SEED_TOKEN=
# SEED_ADMIN_EMAIL=admin@valuefert.com
# SEED_ADMIN_PASSWORD=

# === Email (προαιρετικό — για τη φόρμα επικοινωνίας) ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_TO_EMAIL=info@valuefert.com
